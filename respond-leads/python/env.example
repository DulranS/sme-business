# ──────────────────────────────────────────────
# REQUIRED — API Keys
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# REQUIRED — Discord Configuration
# ──────────────────────────────────────────────

# Option A: Discord Bot (for receiving messages via gateway)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here

# Option B: Discord Webhooks (for sending messages — faster, no bot perms needed)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdef...
DISCORD_SALES_WEBHOOK_URL=https://discord.com/api/webhooks/987654321/xyz...

# Discord Interactions (for slash commands / message components)
DISCORD_PUBLIC_KEY=your_public_key_here

# Channel IDs (where the bot listens and responds)
DISCORD_SUPPORT_CHANNEL_ID=123456789012345678
DISCORD_SALES_CHANNEL_ID=987654321098765432

# ──────────────────────────────────────────────
# OPTIONAL — Redis (falls back to memory-only cache)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# OPTIONAL — RAG Configuration
# ──────────────────────────────────────────────
USE_RAG=false
RAG_TOP_K=5

# ──────────────────────────────────────────────
# OPTIONAL — Webhook Security
# ──────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_here