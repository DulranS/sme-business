# ─────────────────────────────────────────────────────────────────────────────
# RespondLeadz — environment configuration template
#
# Copy this file to `.env.local` (local dev) or configure these as environment
# variables in your deployment platform (e.g. Vercel Project Settings).
# NEVER commit real secrets. `.env*` files are gitignored.
#
# The webhook refuses inbound traffic until every value marked REQUIRED is
# present and non-empty (enforced by ConfigValidator at startup).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (dashboard + PostgREST data access) ────────────────────────────
# REQUIRED. Public values are inlined into the browser bundle at build time.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only service-role key (used by server-side Supabase client). Optional
# but recommended for privileged server operations. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Multi-tenant pipeline database (Postgres + Row Level Security) ───────────
# REQUIRED for the canonical pipeline. The tenant connection MUST use the
# non-superuser `respondleadz_tenant` role created in migration 007 so RLS is
# always enforced (it must NOT be a superuser/BYPASSRLS role).
TENANT_DATABASE_URL=postgres://respondleadz_tenant:password@host:5432/dbname
# Admin/routing connection used only for tenant resolution and the RLS probe.
# A role able to read the `tenants` table (e.g. superuser or BYPASSRLS).
# Falls back to DATABASE_URL if ADMIN_DATABASE_URL is unset.
ADMIN_DATABASE_URL=postgres://admin:password@host:5432/dbname
# DATABASE_URL=postgres://admin:password@host:5432/dbname

# ── WhatsApp Business Cloud API ──────────────────────────────────────────────
# REQUIRED. From the Meta App / WhatsApp Business configuration.
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_APP_SECRET=your-app-secret
# Token you choose; must match the value entered in the Meta webhook setup.
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ── LLM provider (Anthropic Claude Haiku) ────────────────────────────────────
# Optional: when absent, the AI responder returns the fallback response.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Cron authentication ──────────────────────────────────────────────────────
# Recommended in production. When set, the daily lifecycle cron
# (/api/cron/lifecycle) requires `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron attaches this automatically when configured on the project.
CRON_SECRET=your-cron-secret

# ── Sibling system interop (optional) ────────────────────────────────────────
# CashFlow money-tracking webhook that receives close events.
CASHFLOW_WEBHOOK_URL=
# AutoDealz supply feed pulled into tenant inventory.
AUTODEALZ_FEED_URL=

# ── Application ──────────────────────────────────────────────────────────────
# Optional; defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Testing (optional) ───────────────────────────────────────────────────────
# Set to any non-empty value to enable the gated RLS integration tests in
# tests/tenant.test.ts (requires a Postgres test DB with migrations 001-007
# applied and the respondleadz_tenant role). Skipped by default.
# RESPONDLEADZ_TEST_DATABASE=1
